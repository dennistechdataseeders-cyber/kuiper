// backend/scripts/fix-invites.js
// Run with: node scripts/fix-invites.js

const mongoose = require('mongoose');
const dotenv = require('dotenv');
const path = require('path');

dotenv.config({ path: path.resolve(__dirname, '../.env') });

const User = require('../models/User');
const Project = require('../models/Project');
const Feed = require('../models/Feed');
const gitService = require('../services/gitService');

async function fixInvites() {
  console.log('🔧 FIXING GITHUB INVITES');
  console.log('='.repeat(60));
  
  try {
    await mongoose.connect(process.env.MONGO_URI);
    console.log('✅ Connected to MongoDB\n');

    // Find all projects with GitHub repos
    const projects = await Project.find({ 
      gitRepoName: { $ne: null, $exists: true } 
    });

    console.log(`📦 Found ${projects.length} projects with GitHub repos\n`);

    let totalInvited = 0;
    let totalFailed = 0;

    for (const project of projects) {
      console.log(`📁 Project: ${project.projectCustomId}`);
      console.log(`   Repo: ${project.gitRepoName}`);
      
      // Find all feeds in this project
      const feeds = await Feed.find({ projectId: project._id });
      const developerIds = new Set();
      
      for (const feed of feeds) {
        if (feed.assignedDevelopers && feed.assignedDevelopers.length > 0) {
          feed.assignedDevelopers.forEach(id => developerIds.add(id.toString()));
        }
      }

      console.log(`   Developers to invite: ${developerIds.size}`);

      for (const devId of developerIds) {
        const result = await gitService.addCollaboratorById(
          project.gitRepoName,
          devId,
          'push'
        );
        
        if (result.success) {
          console.log(`   ✅ Invited: ${result.username || devId}`);
          totalInvited++;
        } else {
          console.log(`   ❌ Failed: ${devId} - ${result.error}`);
          if (result.inviteLink) {
            console.log(`   🔗 Invite link: ${result.inviteLink}`);
          }
          totalFailed++;
        }
        
        // Rate limiting
        await new Promise(resolve => setTimeout(resolve, 1000));
      }
      
      console.log('');
    }

    console.log('='.repeat(60));
    console.log(`📊 SUMMARY: ${totalInvited} invited, ${totalFailed} failed`);
    
    await mongoose.disconnect();
    console.log('✅ Done!');

  } catch (err) {
    console.error('❌ Error:', err.message);
    process.exit(1);
  }
}

fixInvites();
</file>

