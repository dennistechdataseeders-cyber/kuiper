// backend/scripts/check-org-membership.js
// Run with: node scripts/check-org-membership.js

const { Octokit } = require('@octokit/rest');
const dotenv = require('dotenv');
const path = require('path');

dotenv.config({ path: path.resolve(__dirname, '../.env') });

async function checkMembership() {
  console.log('🔍 CHECKING ORGANIZATION MEMBERSHIP');
  console.log('='.repeat(60));
  
  const token = process.env.GITHUB_TOKEN;
  const owner = 'techdataseeders';
  
  console.log(`🔑 Using token: ${token ? token.substring(0, 10) + '...' : '❌ Not set'}`);
  
  if (!token) {
    console.log('❌ No token found');
    return;
  }

  try {
    const octokit = new Octokit({ 
      auth: token,
      userAgent: 'KUIPER-check-org'
    });
    
    // Get authenticated user
    const user = await octokit.users.getAuthenticated();
    console.log(`\n👤 Authenticated as: ${user.data.login}`);
    console.log(`📧 Email: ${user.data.email || 'Not public'}`);
    
    // Check if this user is a member of the organization
    try {
      const membership = await octokit.orgs.checkMembershipForUser({
        org: owner,
        username: user.data.login
      });
      console.log(`\n✅ ${user.data.login} IS a member of ${owner}`);
      console.log(`   Status: ${membership.status}`);
      console.log(`   Role: ${membership.data.role || 'member'}`);
    } catch (err) {
      if (err.status === 404) {
        console.log(`\n❌ ${user.data.login} is NOT a member of ${owner}`);
        console.log('\n📋 You need to:');
        console.log('1. Ask an organization owner to add you to the organization');
        console.log('2. Or use a token from an organization owner');
        console.log('3. Or use the organization\'s GitHub App token');
      } else {
        console.log(`\n⚠️ Error checking membership: ${err.status} - ${err.message}`);
      }
    }
    
    // List all organizations the user belongs to
    try {
      const orgs = await octokit.users.listOrgsForAuthenticatedUser();
      console.log('\n📋 Organizations you belong to:');
      if (orgs.data.length === 0) {
        console.log('   (None)');
      } else {
        orgs.data.forEach(org => {
          console.log(`   🏢 ${org.login}`);
        });
      }
    } catch (err) {
      console.log(`⚠️ Could not list organizations: ${err.message}`);
    }
    
  } catch (err) {
    console.error('❌ Error:', err.message);
    if (err.status === 401) {
      console.log('🔑 Invalid token - generate a new one');
    }
  }
}

checkMembership();
