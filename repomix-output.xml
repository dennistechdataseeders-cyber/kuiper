// scripts/delete-my-repos.js
// Run with: node scripts/delete-my-repos.js

const dotenv = require('dotenv');
const path = require('path');
const { Octokit } = require('@octokit/rest');

const envPath = path.resolve(__dirname, '../.env');
dotenv.config({ path: envPath });

const GITHUB_TOKEN = process.env.GITHUB_TOKEN;

if (!GITHUB_TOKEN) {
  console.error('❌ GITHUB_TOKEN is not set');
  process.exit(1);
}

const octokit = new Octokit({
  auth: GITHUB_TOKEN,
  userAgent: 'delete-my-repos'
});

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

async function deleteMyRepos() {
  console.log('🗑️  DELETE MY REPOSITORIES');
  console.log('='.repeat(60));

  try {
    // Get authenticated user
    const user = await octokit.users.getAuthenticated();
    console.log(`👤 User: ${user.data.login}`);
    console.log(`📧 Email: ${user.data.email || 'Not public'}`);
    console.log('');

    // Get all repos for the authenticated user
    console.log('📋 Fetching your repositories...');
    const repos = [];
    let page = 1;

    while (true) {
      const response = await octokit.repos.listForAuthenticatedUser({
        per_page: 100,
        page: page,
        headers: { 'X-GitHub-Api-Version': '2022-11-28' }
      });

      repos.push(...response.data);

      if (response.data.length < 100) break;
      page++;
    }

    console.log(`✅ Found ${repos.length} repositories\n`);

    if (repos.length === 0) {
      console.log('No repositories found.');
      return;
    }

    // Filter to only techdataseeders repos if needed
    const filteredRepos = repos.filter(repo => 
      repo.name.includes('tds') || 
      repo.name.includes('TDS') ||
      repo.name.includes('data') ||
      repo.name.includes('feed')
    );

    console.log(`📋 Repositories to delete (${filteredRepos.length}):`);
    filteredRepos.forEach((repo, i) => {
      console.log(`   ${i + 1}. ${repo.name}`);
    });
    console.log('');

    if (filteredRepos.length === 0) {
      console.log('No matching repositories found.');
      return;
    }

    console.log('⚠️  WARNING: These repositories will be DELETED!');
    console.log('   Press Ctrl+C to cancel, or wait 10 seconds...');
    await sleep(10000);

    console.log('\n🗑️  DELETING...\n');

    for (const repo of filteredRepos) {
      try {
        await octokit.repos.delete({
          owner: user.data.login,
          repo: repo.name,
          headers: { 'X-GitHub-Api-Version': '2022-11-28' }
        });
        console.log(`   ✅ Deleted: ${repo.name}`);
      } catch (err) {
        console.log(`   ❌ Failed: ${repo.name} - ${err.message}`);
      }
      await sleep(1000);
    }

    console.log('\n✅ Done!');

  } catch (err) {
    console.error('❌ Error:', err.message);
  }
}

deleteMyRepos();
