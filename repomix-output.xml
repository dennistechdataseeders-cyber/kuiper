        userOrgId = '6a22b2e00ee6695c87c21d6b';
        console.log('Using hardcoded organization ID for testing:', userOrgId);
      }
      
      // Fetch all projects
      const projectsRes = await axios.get(`${API_BASE_URL}/api/admin/projects`, {
        headers: headers
