// backend/scripts/check-github-repos.js
// Run with: node scripts/check-github-repos.js

const { Octokit } = require('@octokit/rest');
const mongoose = require('mongoose');
const dotenv = require('dotenv');
const path = require('path');

dotenv.config({ path: path.resolve(__dirname, '../.env') });

const Project = require('../models/Project');

async function checkRepos() {
  console.log('🔍 CHECKING GITHUB REPOSITORIES');
  console.log('='.repeat(60));
  
  const token = process.env.GITHUB_TOKEN;
  const owner = 'techdataseeders';
  
  if (!token) {
    console.log('❌ No GITHUB_TOKEN found');
    return;
  }

  try {
    const octokit = new Octokit({ 
      auth: token,
      userAgent: 'KUIPER-check'
    });
    
    await mongoose.connect(process.env.MONGO_URI);
    console.log('✅ Connected to MongoDB\n');

    // Get all projects with git repo names
    const projects = await Project.find({ 
      gitRepoName: { $ne: null, $exists: true } 
    });

    console.log(`📦 ${projects.length} projects with Git repo names in DB\n`);

    // Try to list repos from GitHub
    console.log('📡 Checking GitHub organization...');
    let existingRepos = [];
    
    try {
      const response = await octokit.repos.listForOrg({
        org: owner,
        per_page: 100
      });
      existingRepos = response.data.map(r => r.name);
      console.log(`✅ Found ${existingRepos.length} repositories in organization\n`);
    } catch (err) {
      if (err.status === 404) {
        console.log(`❌ Organization "${owner}" not found or token doesn't have access`);
        console.log('   This means the repositories don\'t exist or you can\'t see them');
      } else {
        console.log(`❌ Error: ${err.status} - ${err.message}`);
      }
      await mongoose.disconnect();
      return;
    }

    console.log('📋 REPOSITORY STATUS:');
    console.log('='.repeat(60));
    
    for (const project of projects) {
      const repoName = project.gitRepoName;
      const exists = existingRepos.includes(repoName);
      
      console.log(`\n📁 ${project.projectCustomId}`);
      console.log(`   Repo: ${repoName}`);
      console.log(`   Status: ${exists ? '✅ EXISTS' : '❌ NOT FOUND'}`);
      
      if (exists) {
        const inviteLink = `https://github.com/${owner}/${repoName}/invite`;
        console.log(`   🔗 ${inviteLink}`);
      } else {
        console.log(`   💡 Repository needs to be created`);
      }
    }

    console.log('\n' + '='.repeat(60));
    console.log(`📊 Summary: ${existingRepos.length} repos exist, ${projects.length - existingRepos.length} missing`);

    await mongoose.disconnect();
    console.log('\n✅ Done!');

  } catch (err) {
    console.error('❌ Error:', err.message);
    console.error(err.stack);
    process.exit(1);
  }
}

checkRepos();
</file>

