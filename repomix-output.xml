// scripts/nuke-and-recreate-from-json.js
// Run with: node scripts/nuke-and-recreate-from-json.js

const fs = require('fs');
const path = require('path');
const dotenv = require('dotenv');

// Load .env from backend root
const envPath = path.resolve(__dirname, '../.env');
console.log(`📁 Looking for .env at: ${envPath}`);
dotenv.config({ path: envPath });

const { Octokit } = require('@octokit/rest');

const GITHUB_TOKEN = process.env.GITHUB_TOKEN;
const GITHUB_OWNER = process.env.GITHUB_OWNER;

console.log('📋 Configuration:');
console.log(`   GITHUB_TOKEN: ${GITHUB_TOKEN ? '✅ Set' : '❌ Not set'}`);
console.log(`   GITHUB_OWNER: ${GITHUB_OWNER || '❌ Not set'}`);
console.log('');

if (!GITHUB_TOKEN || !GITHUB_OWNER) {
  console.error('❌ Missing required environment variables');
  process.exit(1);
}

// Load JSON data
const projectsJsonPath = path.resolve(__dirname, '../scripts/kuiper.projects.json');
const feedsJsonPath = path.resolve(__dirname, '../scripts/kuiper.feeds.json');

if (!fs.existsSync(projectsJsonPath)) {
  console.error(`❌ Projects JSON file not found: ${projectsJsonPath}`);
  process.exit(1);
}

if (!fs.existsSync(feedsJsonPath)) {
  console.error(`❌ Feeds JSON file not found: ${feedsJsonPath}`);
  process.exit(1);
}

const projectsData = JSON.parse(fs.readFileSync(projectsJsonPath, 'utf8'));
const feedsData = JSON.parse(fs.readFileSync(feedsJsonPath, 'utf8'));

console.log(`📊 Loaded ${projectsData.length} projects and ${feedsData.length} feeds\n`);

// Build feed lookup by project ID
const feedsByProject = {};
feedsData.forEach(feed => {
  const projectId = feed.projectId?.$oid;
  if (projectId) {
    if (!feedsByProject[projectId]) {
      feedsByProject[projectId] = [];
    }
    feedsByProject[projectId].push(feed);
  }
});

// Build project map with their feeds
const projects = projectsData.map(project => {
  const projectId = project._id.$oid;
  const feeds = feedsByProject[projectId] || [];
  return {
    ...project,
    projectId: projectId,
    feeds: feeds,
    feedCount: feeds.length
  };
});

console.log('📋 Projects to recreate:');
projects.forEach((p, i) => {
  console.log(`   ${i + 1}. ${p.projectCustomId || p.name} (${p.feedCount} feeds)`);
});
console.log('');

const octokit = new Octokit({
  auth: GITHUB_TOKEN,
  userAgent: 'KUIPER-nuke-script',
  request: { timeout: 30000 }
});

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function sanitizeRepoName(name) {
  if (!name) return 'project';
  let cleaned = name
    .toLowerCase()
    .replace(/[^a-z0-9-]/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
  return cleaned.substring(0, 100) || 'project';
}

function sanitizeFeedName(name) {
  if (!name) return 'feed';
  let cleaned = name
    .toLowerCase()
    .replace(/[^a-z0-9-]/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
  return cleaned.substring(0, 100) || 'feed';
}

// Get ALL repositories in the organization
async function getAllRepos() {
  try {
    console.log('📋 Fetching all repositories from GitHub...');
    const repos = [];
    let page = 1;
    
    while (true) {
      const response = await octokit.repos.listForOrg({
        org: GITHUB_OWNER,
        per_page: 100,
        page: page,
        headers: { 'X-GitHub-Api-Version': '2022-11-28' }
      });
      
      repos.push(...response.data);
      
      if (response.data.length < 100) break;
      page++;
    }
    
    console.log(`   ✅ Found ${repos.length} repositories\n`);
    return repos;
  } catch (err) {
    if (err.status === 404) {
      console.log(`   ⚠️  Organization ${GITHUB_OWNER} not found`);
      return [];
    }
    console.error('❌ Failed to fetch repositories:', err.message);
    return [];
  }
}

// Delete a repository with retry
async function deleteRepo(repoName, attempt = 1) {
  try {
    console.log(`   Attempt ${attempt}: Deleting ${repoName}...`);
    
    await octokit.repos.delete({
      owner: GITHUB_OWNER,
      repo: repoName,
      headers: { 'X-GitHub-Api-Version': '2022-11-28' }
    });
    
    console.log(`   ✅ Deleted: ${repoName}`);
    return { success: true };
  } catch (err) {
    if (err.status === 404) {
      console.log(`   ℹ️  ${repoName} not found (already deleted)`);
      return { success: true };
    }
    
    if (err.status === 403) {
      console.log(`   ❌ Cannot delete ${repoName}: Insufficient permissions`);
      console.log(`   🔑 Your token needs 'delete_repo' scope`);
      return { success: false, error: 'Insufficient permissions' };
    }
    
    if (attempt < 3) {
      console.log(`   ⚠️  Attempt ${attempt} failed, retrying...`);
      await sleep(3000);
      return deleteRepo(repoName, attempt + 1);
    }
    
    console.log(`   ❌ Failed to delete ${repoName}: ${err.message}`);
    return { success: false, error: err.message };
  }
}

// Create a repository
async function createRepo(project) {
  try {
    const repoName = sanitizeRepoName(project.projectCustomId || project.name);
    const description = (project.description || 'Project from KUIPER CRM').substring(0, 300);
    
    console.log(`   📦 Creating: ${repoName}`);
    
    // Check if exists
    try {
      await octokit.repos.get({
        owner: GITHUB_OWNER,
        repo: repoName
      });
      console.log(`   ⚠️  ${repoName} already exists, skipping`);
      return { success: false, error: 'Already exists', repoName };
    } catch (err) {
      if (err.status !== 404) throw err;
    }
    
    const response = await octokit.repos.createForAuthenticatedUser({
      name: repoName,
      description: description,
      private: true,
      auto_init: true,
      has_issues: true,
      has_projects: true,
      has_wiki: true,
      headers: { 'X-GitHub-Api-Version': '2022-11-28' }
    });
    
    console.log(`   ✅ Created: ${repoName}`);
    return {
      success: true,
      repoName: repoName,
      repoUrl: response.data.html_url
    };
  } catch (err) {
    console.log(`   ❌ Failed to create: ${err.message}`);
    return { success: false, error: err.message };
  }
}

// Create feed folder structure
async function createFeedFolder(repoName, feed, project) {
  try {
    const folderName = sanitizeFeedName(feed.name || 'feed');
    
    // Build README content with all feed details
    const feedType = feed.feedType || 'Daily';
    const weekDay = feed.weekDay || '';
    const monthDay = feed.monthDay || '';
    const feedPlatform = feed.feedPlatform || '';
    const webDomain = feed.webDomain || '';
    const feedStatus = feed.feedStatus || 'New';
    
    let readmeContent = `# ${feed.name}

## Feed Information
- **Feed ID**: ${feed._id?.$oid || feed._id}
- **Project**: ${project.projectCustomId || project.name}
- **Type**: ${feedType}
${weekDay ? `- **Day**: ${weekDay}` : ''}
${monthDay ? `- **Day of Month**: ${monthDay}` : ''}
${feedPlatform ? `- **Platform**: ${feedPlatform}` : ''}
${webDomain ? `- **Domain**: ${webDomain}` : ''}
- **Status**: ${feedStatus}

## Structure
- \`/docs\` - Documentation
- \`/src\` - Source code
- \`/tests\` - Test files
- \`/config\` - Configuration files

## Last Updated
${new Date().toISOString()}

---
*Automatically generated by KUIPER CRM*
`;

    const readmeBase64 = Buffer.from(readmeContent).toString('base64');
    
    // Create README
    try {
      await octokit.repos.createOrUpdateFileContents({
        owner: GITHUB_OWNER,
        repo: repoName,
        path: `${folderName}/README.md`,
        message: `feat: Add feed folder for ${feed.name}`,
        content: readmeBase64,
        committer: {
          name: 'KUIPER CRM',
          email: 'noreply@kuiper.com'
        },
        headers: { 'X-GitHub-Api-Version': '2022-11-28' }
      });
      console.log(`   📁 Created: ${folderName}/README.md`);
    } catch (err) {
      console.log(`   ⚠️  Could not create README: ${err.message}`);
    }

    // Create subfolders
    const subfolders = ['docs', 'src', 'tests', 'config'];
    for (const sub of subfolders) {
      try {
        await octokit.repos.createOrUpdateFileContents({
          owner: GITHUB_OWNER,
          repo: repoName,
          path: `${folderName}/${sub}/.gitkeep`,
          message: `chore: Initialize ${sub} folder for ${feed.name}`,
          content: Buffer.from('').toString('base64'),
          committer: {
            name: 'KUIPER CRM',
            email: 'noreply@kuiper.com'
          },
          headers: { 'X-GitHub-Api-Version': '2022-11-28' }
        });
      } catch (err) {
        // Continue even if subfolder fails
      }
      await sleep(200);
    }

    return { success: true };
  } catch (err) {
    console.log(`   ❌ Failed to create feed: ${err.message}`);
    return { success: false, error: err.message };
  }
}

// MAIN FUNCTION
async function nukeAndRecreate() {
  console.log('💣 NUKE GITHUB REPOSITORIES (From JSON)');
  console.log('='.repeat(60));
  console.log('⚠️  WARNING: This will DELETE ALL repositories in the organization!');
  console.log('⚠️  Using JSON data only - no database connection needed.');
  console.log('');

  try {
    // STEP 1: Delete ALL repositories
    const allRepos = await getAllRepos();
    
    if (allRepos.length > 0) {
      console.log(`⚠️  Found ${allRepos.length} repositories in GitHub`);
      console.log('   These will be DELETED permanently!');
      console.log('   Press Ctrl+C to cancel, or wait 10 seconds...');
      await sleep(10000);
      
      console.log('\n🗑️  DELETING REPOSITORIES...\n');
      let deleted = 0;
      let failed = 0;
      
      for (const repo of allRepos) {
        const result = await deleteRepo(repo.name);
        if (result.success) {
          deleted++;
        } else {
          failed++;
        }
        await sleep(1000);
      }
      
      console.log(`\n📊 Deleted: ${deleted}, Failed: ${failed}`);
      
      if (failed > 0) {
        console.log('\n⚠️  Some repositories could not be deleted automatically.');
        console.log('   You may need to delete them manually from:');
        console.log(`   https://github.com/${GITHUB_OWNER}?tab=repositories`);
        console.log('\n   Press Ctrl+C to cancel, or wait 15 seconds to continue...');
        await sleep(15000);
      }
    } else {
      console.log('✅ No repositories found to delete.');
    }

    // Wait for GitHub
    console.log('\n⏳ Waiting 10 seconds for GitHub to process...');
    await sleep(10000);

    // STEP 2: Recreate all projects
    console.log('\n🔨 RECREATING PROJECTS...\n');
    
    let successCount = 0;
    let failCount = 0;

    for (let i = 0; i < projects.length; i++) {
      const project = projects[i];
      console.log(`\n${'='.repeat(60)}`);
      console.log(`📦 [${i + 1}/${projects.length}] ${project.projectCustomId || project.name}`);
      console.log(`${'='.repeat(60)}`);
      
      // Create repository
      const createResult = await createRepo(project);
      
      if (!createResult.success) {
        failCount++;
        continue;
      }

      // Create feed folders
      const feeds = project.feeds || [];
      if (feeds.length > 0) {
        console.log(`\n📁 Creating ${feeds.length} feed folders...`);
        for (const feed of feeds) {
          await createFeedFolder(createResult.repoName, feed, project);
          await sleep(500);
        }
      } else {
        console.log(`   ℹ️  No feeds to create`);
      }

      console.log(`\n🔗 Invite link: https://github.com/${GITHUB_OWNER}/${createResult.repoName}/invite`);
      successCount++;
    }

    // Final summary
    console.log('\n' + '='.repeat(60));
    console.log('📊 FINAL SUMMARY');
    console.log('='.repeat(60));
    console.log(`✅ Created: ${successCount}`);
    console.log(`❌ Failed: ${failCount}`);
    console.log(`📦 Total Projects: ${projects.length}`);
    console.log(`📁 Total Feeds: ${projects.reduce((sum, p) => sum + p.feedCount, 0)}`);
    console.log('\n✅ Script completed!');

  } catch (error) {
    console.error('\n❌ Fatal error:', error.message);
    console.error(error.stack);
  }
}

nukeAndRecreate();
